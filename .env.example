# n8n
N8N_BASE_URL=https://your-n8n-instance.example.com

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Pipedrive
PIPEDRIVE_API_KEY=your_pipedrive_api_key

# Google Services
GOOGLE_DRIVE_CREDENTIALS=your_google_drive_credentials
GMAIL_CREDENTIALS=your_gmail_credentials
GOOGLE_CALENDAR_CREDENTIALS=your_google_calendar_credentials

# Firecrawl
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Pushover
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_API_TOKEN=your_pushover_api_token

# Webhook URLs
DEAL_RECORDING_WEBHOOK_URL=https://your-n8n-instance/webhook/deal-recording
DEMO_BOOKING_WEBHOOK_URL=https://your-n8n-instance/webhook/demo-booking